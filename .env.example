# ───────────────────────── CookMate environment ─────────────────────────
# Copy this file to `.env` (git-ignored) and fill it in.
#
# OPTION A — Claude API (easiest, just an API key):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=          # optional; default claude-opus-4-8 (claude-haiku-4-5 = faster/cheaper)
#
# PREFERRED: Vertex AI — spend draws from your Google Cloud CREDITS.
# Reuse the SAME values your green-card-guide / firm-bot project already uses:
#   open  D:\AI Chatbot\firm-bot\.env  and copy these three across.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
# Paste the service-account JSON on ONE line, OR a base64 of it:
GOOGLE_VERTEX_CREDENTIALS=
# ── alternative to the line above: a path to the SA json file (ADC) ──
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# FALLBACK ONLY: Gemini Developer API key.
# NOTE: this path does NOT use GCP credits — it bills a separate Gemini account.
GEMINI_API_KEY=

# Optional
GEMINI_MODEL=
PORT=5599
